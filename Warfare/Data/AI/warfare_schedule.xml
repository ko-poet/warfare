<?xml version="1.0" encoding="us-ascii"?>
<BehaviorTrees>
	<BehaviorTree name="onUpdate" is_function="0">
		<Variables>
			<Variable name="attackData" type="switch:interruptData:attack" values="" isPersistent="0" form="single" />
			<Variable name="command" type="_string" values="attack" isPersistent="0" form="single" />
			<Variable name="fight" type="_bool" values="false" isPersistent="0" form="single" />
			<Variable name="isFollowing" type="_bool" values="false" isPersistent="0" form="single" />
			<Variable name="mrkev" type="_wuid" values="" isPersistent="0" form="single" />
			<Variable name="target" type="_wuid" values="" isPersistent="0" form="single" />
			<Variable name="visorDown" type="_bool" values="false" isPersistent="0" form="single" />
		</Variables>
		<Root OneTimeOnly="false" FailState="Recoverable" saveVersion="2">
			<Behavior canSkip="1">
				<Parallel successMode="Any" failureMode="Any">
					<Loop count="-1">
						<Sequence>
							<ExecuteLua code="data.fight = Warfare.fight &#10;data.visorDown = Warfare.getVisor(entity) &#10;data.command = Warfare.getCommand(entity)" />
							<IfCondition failOnCondition="false" condition="$visorDown">
								<Sequence>
									<Function_crime_getMrkev mrkev="$mrkev" nodeLabel="87643362" />
									<AddInterrupt Target="$this.id" Host="$mrkev" Behavior="&apos;warfare_visor&apos;" Priority="160" IgnorePriorityOnPreviousInterrupt="true" urgency="Fast" Aliveness="Alive" Privileged="false" FastForward="false" />
									<ExecuteLua code="Warfare.setVisor(entity, false) &#10;data.visorDown = false &#10;Warfare.brainLog(entity, &quot;Visor down&quot;)" />
								</Sequence>
							</IfCondition>
							<IfCondition failOnCondition="false" condition="$fight &amp; $command == &apos;attack&apos; | $command == &apos;hold&apos;">
								<EntityContextCheck context="crime_interruptAttack" target="$this.id" saveVersion="2">
									<Else canSkip="1">
										<Sequence>
											<Expression expressions="$target = $__null" />
											<ExecuteLua code="data.target = Warfare:getClosestTarget(entity, Warfare.SpawnedEntities).this.id" />
											<IfCondition failOnCondition="false" condition="$target ~= $__null">
												<Sequence>
													<ExecuteLua code="Warfare.brainLog(entity, &quot;Calling attack&quot;)" />
													<Function_crime_getMrkev mrkev="$mrkev" nodeLabel="25225112" />
													<Expression expressions="$attackData.target = $target" />
													<AddInterrupt_attack attackData="$attackData" Target="$this.id" Host="$mrkev" Behavior="&apos;warfare_attack&apos;" Priority="160" IgnorePriorityOnPreviousInterrupt="true" urgency="Fast" Aliveness="Alive" Privileged="false" FastForward="false" />
												</Sequence>
											</IfCondition>
										</Sequence>
									</Else>
								</EntityContextCheck>
							</IfCondition>
							<IfElseCondition failOnCondition="false" condition="$command == &apos;follow&apos;" saveVersion="2">
								<Then canSkip="1">
									<IfCondition failOnCondition="false" condition="~$isFollowing">
										<Sequence>
											<Expression expressions="$isFollowing = true" />
											<Function_crime_getMrkev mrkev="$mrkev" nodeLabel="81908158" />
											<AddInterrupt Target="$this.id" Host="$mrkev" Behavior="&apos;warfare_follow&apos;" Priority="160" IgnorePriorityOnPreviousInterrupt="true" urgency="Fast" Aliveness="Alive" Privileged="false" FastForward="false" />
										</Sequence>
									</IfCondition>
								</Then>
								<Else canSkip="1">
									<Expression expressions="$isFollowing = false" />
								</Else>
							</IfElseCondition>
							<Wait duration="&apos;100&apos;" timeType="GameTime" doFail="false" variation="&apos;10&apos;" />
						</Sequence>
					</Loop>
					<Loop count="-1">
						<Sequence>
							<DialogGate Who="$this.id" Negation="false" EndDialogInRoot="false" Condition="InChat" RunLogic="KeepRunning">
								<ExecuteLua code="Warfare.brainLog(entity, &quot;Chatting&quot;) &#10;Warfare:setChatTarget(entity)" />
							</DialogGate>
							<Wait duration="&apos;100&apos;" timeType="GameTime" doFail="false" variation="&apos;10&apos;" />
						</Sequence>
					</Loop>
				</Parallel>
			</Behavior>
		</Root>
