			<Variable name="distance" type="_float" values="0" isPersistent="0" form="single" />
			<Variable name="exit" type="_bool" values="false" isPersistent="0" form="single" />
			<Variable name="fight" type="_bool" values="true" isPersistent="0" form="single" />
			<Variable name="guardMode" type="enum:combatAutomationGuardMode" values="$enum:combatAutomationGuardMode.automate" isPersistent="0" form="single" />
			<Variable name="isRanged" type="_bool" values="false" isPersistent="0" form="single" />
			<Variable name="isTargetAlive" type="_bool" values="true" isPersistent="0" form="single" />
			<Variable name="reload" type="_bool" values="true" isPersistent="0" form="single" />
			<Variable name="soldierType" type="_int" values="1" isPersistent="0" form="single" />
			<Variable name="target" type="_wuid" values="" isPersistent="0" form="single" />
			<Variable name="weaponChange" type="enum:weaponChange" values="$enum:weaponChange.none" isPersistent="0" form="single" />
		</Variables>
		<Parameters>
			<Variable name="attackData" type="switch:interruptData:attack" values="" isPersistent="0" form="single" requirementType="In" />
		</Parameters>
		<Root OneTimeOnly="false" FailState="Recoverable" saveVersion="2">
			<Behavior canSkip="1">
				<EntityContextElement context="crime_interrupt" enabled="true">
					<EntityContext context="crime_interruptAttack" target="$this.id">
						<Sequence>
							<Expression expressions="$target = $attackData.target" />
							<ExecuteLua code="Warfare.brainLog(entity, &quot;attack start&quot;) &#10; &#10;if Warfare:isRanged(entity) then &#10;data.isRanged = true &#10;data.weaponChange = enum_weaponChange.missile &#10;end" />
							<FuseBox StatusPropagation="Child" OneCleanup="true" saveVersion="2">
								<Child canSkip="1">
									<Parallel successMode="Any" failureMode="Any">
										<Loop count="-1">
											<Sequence>
												<MoveParamsDecorator speed="Run" pathFindingParams="" doorClosingPolicy="LeaveOpened">
													<MeleeDefenseAutomationDecorator active="$automation_defense">
														<MeleeGuardAutomationDecorator GuardMode="$guardMode" active="$automation_guard">
															<WeaponAutomationDecorator WeaponChange="$weaponChange" active="$automation_weapon">
																<CombatFollowerDecorator ProbablisticDrivenSweetSpot="true" RPGSweetSpotArcDriver="true" active="$automation_movement">
																	<MeleeOffenseAutomationDecorator active="$automation_offense">
																		<CombatAction TargetNPC="$target" RelationOverride="Hostile" />
																	</MeleeOffenseAutomationDecorator>
																</CombatFollowerDecorator>
															</WeaponAutomationDecorator>
														</MeleeGuardAutomationDecorator>
													</MeleeDefenseAutomationDecorator>
												</MoveParamsDecorator>
												<ExecuteLua code="Warfare.brainLog(entity, &quot;loop&quot;)" />
											</Sequence>
										</Loop>
										<Loop count="-1">
											<Sequence>
												<ExecuteLua code="local cmd = Warfare.getCommand(entity) &#10;data.distance = Warfare.getEntDistance(entity, XGenAIModule.GetEntityByWUID(data.target)) &#10; &#10;if data.isRanged and data.distance &gt; 4 then &#10;data.weaponChange = enum_weaponChange.missile &#10;elseif Warfare.getType(entity) == &quot;spearmen&quot; then &#10;data.weaponChange = enum_weaponChange.oversized &#10;else &#10;data.weaponChange = enum_weaponChange.melee &#10;end &#10; &#10;local targetEnt = Warfare:getClosestTarget(entity, Warfare.SpawnedEntities) &#10;if data.target ~= targetEnt.this.id then &#10;data.target = targetEnt.this.id &#10;data.reload = true &#10;end &#10; &#10;if not Warfare.fight or cmd == &apos;follow&apos; then &#10;data.exit = true &#10;end" />
												<IfCondition failOnCondition="false" condition="$exit">
													<Fail />
												</IfCondition>
												<Wait duration="&apos;100&apos;" timeType="GameTime" doFail="false" variation="&apos;10&apos;" />
											</Sequence>
										</Loop>
									</Parallel>
								</Child>
								<OnFail canSkip="1">
									<ExecuteLua code="Warfare.brainLog(entity, &quot;attack stop&quot;)" />
								</OnFail>
							</FuseBox>
						</Sequence>
					</EntityContext>
				</EntityContextElement>
			</Behavior>
		</Root>
		<ForestContainer>
			<ContinuousSwitch>
				<IfCondition failOnCondition="false" condition="$reload" />
				<IfCondition failOnCondition="false" condition="true">
					<Wait duration="&apos;100&apos;" timeType="GameTime" doFail="false" variation="&apos;10&apos;" />
				</IfCondition>
			</ContinuousSwitch>
			<Expression expressions="$reload = false" />
		</ForestContainer>
